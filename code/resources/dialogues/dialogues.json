			},
			"ask_village": {
				"node_id": "chenmo_ask_village",
				"trust_required": 0,
				"lines": [
					{"speaker": "player", "text": "这个村子情况怎么样？"},
					{"speaker": "chenmo", "text": "......"},
					{"speaker": "chenmo", "text": "和别的村子一样。没什么特别的。"},
					{"speaker": "chenmo", "text": "想知道什么，去问别人。我只是个打杂的。"}
