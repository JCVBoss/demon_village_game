			"friendly_greeting": {
				"node_id": "chenmo_friendly_greeting",
				"trust_required": 0,
				"lines": [
					{"speaker": "player", "text": "你好，我叫勇者。听说村子需要帮忙？"},
					{"speaker": "chenmo", "text": "......帮忙？"},
					{"speaker": "chenmo", "text": "（沉默片刻）如果你真的想帮忙，去找大熊吧。"},
					{"speaker": "chenmo", "text": "酒馆在东边。他比我...更会说话。"}
