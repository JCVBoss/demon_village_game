			},
			"why_not_help": {
				"node_id": "chenmo_why_not_help",
				"trust_required": 0,
				"lines": [
					{"speaker": "chenmo", "text": "（眼神闪过一丝痛苦）"},
					{"speaker": "chenmo", "text": "帮忙......我连自己都帮不了。"},
					{"speaker": "chenmo", "text": "别问了。去做你该做的事吧。"}
				],
				"choices": [
					{"text": "好吧，告辞", "trust_change": 0, "next_node": null}
				]
			},
			"notice_something": {
				"node_id": "chenmo_notice_something",
				"trust_required": 0,
				"lines": [
					{"speaker": "chenmo", "text": "（身体微微僵硬）"},
					{"speaker": "chenmo", "text": "......你看错了。"},
					{"speaker": "chenmo", "text": "我只是累了。村子里的事...和你没关系。"}
